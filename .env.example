# Analytics Configuration
# Copy this file to .env.local and fill in your actual values

# Google Analytics 4 Measurement ID
# Get this from your GA4 property settings (e.g., G-XXXXXXXXXX)
VITE_GA_MEASUREMENT_ID=YOUR_GA_MEASUREMENT_ID_HERE

# Google Search Console Verification Code
# Get this from Google Search Console > Settings > Verification
VITE_GSC_VERIFICATION_CODE=YOUR_GSC_VERIFICATION_CODE_HERE